# REMI Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# =============================================================================
# Deployment Mode
# =============================================================================
# Which deployment are we in: "local" or "cloud"
REMI_DEPLOYMENT=local

# Application bind address
# For local: 127.0.0.1 (default) keeps it on localhost only.
# Only change to 0.0.0.0 if you understand the security implications.
REMI_HOST=127.0.0.1
REMI_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
REMI_LOG_LEVEL=INFO

# =============================================================================
# Storage Backend
# =============================================================================
# Options: sqlite, dynamodb
# v1.0 supports sqlite only. dynamodb stub raises NotImplementedError.
STORAGE_BACKEND=sqlite

# SQLite settings (used when STORAGE_BACKEND=sqlite)
SQLITE_PATH=./data/remi.db

# DynamoDB settings (used when STORAGE_BACKEND=dynamodb — v1.1)
# DYNAMODB_REGION=us-east-1
# DYNAMODB_PEOPLE_TABLE=remi-people
# DYNAMODB_INTERACTIONS_TABLE=remi-interactions
# DYNAMODB_OPEN_LOOPS_TABLE=remi-open-loops
# DYNAMODB_AUDIT_TABLE=remi-audit-log

# =============================================================================
# Blob (Audio File) Backend
# =============================================================================
# Options: filesystem, s3
# v1.0 supports filesystem only. s3 stub raises NotImplementedError.
BLOB_BACKEND=filesystem

# Filesystem settings
BLOB_FILESYSTEM_PATH=./audio_storage

# S3 settings (v1.1)
# BLOB_S3_BUCKET=remi-audio-yourid
# BLOB_S3_REGION=us-east-1

# Audio retention in days (cleanup task deletes older files)
AUDIO_RETENTION_DAYS=7

# =============================================================================
# AI Provider
# =============================================================================
# Options: anthropic, ollama, openai, bedrock, custom
# v1.0 ships with anthropic and ollama implemented.
# openai, bedrock, custom are stubs in v1.0.
AI_PROVIDER=anthropic

# --- Anthropic ---
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Ollama (local model) ---
# OLLAMA_MODEL=llama3.1:8b
#
# Two ways to run Ollama:
#
# 1. Bundled container (default): `docker compose up`.
#    OLLAMA_BASE_URL is set automatically to the internal container address.
#    Do NOT set it here — inside the container, localhost points at REMI itself.
#
# 2. Your host's existing Ollama (reuse already-downloaded models):
#    docker compose -f docker-compose.yml -f docker-compose.host-ollama.yml up
#    That override sets OLLAMA_BASE_URL to http://host.docker.internal:11434.
#    You don't need to set OLLAMA_BASE_URL here for either mode.

# --- OpenAI (v1.0 stub) ---
# OPENAI_API_KEY=your-key-here
# OPENAI_MODEL=gpt-4o

# --- AWS Bedrock (v1.0 stub) ---
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Custom HTTP endpoint (v1.0 stub) ---
# For corporate AI gateways with OpenAI-compatible APIs
# CUSTOM_AI_ENDPOINT=https://internal.company.com/llm/v1
# CUSTOM_AI_API_KEY=your-corp-token
# CUSTOM_AI_MODEL=company-approved-model

# =============================================================================
# Transcription Provider
# =============================================================================
# Options: whisper_api, whisper_local (stub in v1.0)
TRANSCRIPTION_PROVIDER=whisper_api

# --- OpenAI Whisper API ---
WHISPER_API_KEY=your-openai-key-here
WHISPER_MODEL=whisper-1

# --- Local Whisper (v1.0 stub) ---
# WHISPER_LOCAL_MODEL_SIZE=base

# =============================================================================
# Security
# =============================================================================
# Local API auth (optional in v1.0 — localhost-only by default)
# If you expose REMI to a network, set this and enable auth.
# REMI_API_KEY=

# CORS allowed origins (comma-separated)
# For local development, default works. For network exposure, lock to your frontend origin.
REMI_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Max raw input length (chars) — prompt injection / DoS defense
REMI_MAX_INPUT_LENGTH=50000

# =============================================================================
# Audit Logging
# =============================================================================
AUDIT_LOG_ENABLED=true
# For local: file or sqlite_table
# For cloud (v1.1): dynamodb
AUDIT_LOG_BACKEND=sqlite_table
